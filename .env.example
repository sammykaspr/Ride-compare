# Backend env. Copy to .env and fill in values.

# Local Postgres via docker-compose:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ridecompare
# Neon (production) — replace with your connection string and add ?sslmode=require:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Required for real distance/duration. Without it the backend falls back to a
# haversine + road-factor mock.
GOOGLE_MAPS_API_KEY=

# Set to true to force the mock even when a key is set (handy for offline dev).
USE_MOCK_DISTANCE=false
